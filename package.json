{
  "name": "job-fit-extension",
  "private": true,
  "version": "0.0.0",
  "description": "LinkedIn Job Fit: Chrome extension + Fastify backend + Vite prefs web app",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify:rls": "tsx --env-file=.env.local scripts/supabase/verify-rls.ts",
    "seed:web-user": "tsx --env-file=.env.local scripts/supabase/seed-web-user.mts",
    "web:dev": "pnpm --filter @job-fit/web dev",
    "web:build": "pnpm --filter @job-fit/web build",
    "ext:dev": "pnpm --filter @job-fit/extension dev",
    "ext:build": "pnpm --filter @job-fit/extension build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@biomejs/biome": "^2.4.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.20.6",
    "vitest": "^4.1.5"
  }
}
