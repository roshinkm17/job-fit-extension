{
  "name": "@job-fit/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx --env-file=../../.env.local --watch src/server.ts",
    "start": "node dist/server.js",
    "smoke": "pnpm -w --filter @job-fit/shared build && tsx --env-file=../../.env.local scripts/smoke.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.3",
    "@job-fit/llm": "workspace:*",
    "@job-fit/shared": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "jose": "^6.1.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
