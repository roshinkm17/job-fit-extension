{
  "name": "@job-fit/extension",
  "displayName": "RoleGauge",
  "version": "0.0.1",
  "private": true,
  "description": "Score LinkedIn job posts against your saved preferences (RoleGauge).",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@job-fit/shared": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.287",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "manifest": {
    "name": "RoleGauge",
    "description": "See how well a LinkedIn job post matches your RoleGauge preferences.",
    "host_permissions": [
      "https://*.linkedin.com/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*",
      "https://*.supabase.co/*"
    ],
    "permissions": [
      "storage"
    ],
    "externally_connectable": {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ]
    }
  }
}
