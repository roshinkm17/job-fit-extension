# Plasmo inlines PLASMO_PUBLIC_* at build time. Copy to .env and fill in.

# Job Fit Fastify API (must match BACKEND_CORS_ORIGINS + host_permissions if not localhost).
PLASMO_PUBLIC_BACKEND_URL=http://localhost:3000

# Same Supabase project as apps/web and apps/backend.
PLASMO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PLASMO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Preferences web app origin (used for session hand-off security + error links).
PLASMO_PUBLIC_WEB_APP_URL=http://localhost:5173

# Set to 1 to keep the Phase 7 deterministic mock instead of calling POST /analyze.
# PLASMO_PUBLIC_USE_MOCK_ANALYZE=1
