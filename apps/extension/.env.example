# Plasmo inlines `PLASMO_PUBLIC_*` at build time. Copy to `.env` in this directory:
#   cp .env.example .env
#
# Use the same Supabase project and API base URL as the repo root `.env.local`.
# `apps/extension/.env` is gitignored; `.env.example` is committed.

PLASMO_PUBLIC_BACKEND_URL=http://localhost:3000
PLASMO_PUBLIC_SUPABASE_URL=
PLASMO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
PLASMO_PUBLIC_WEB_APP_URL=http://localhost:5173

# Optional: do not call POST /analyze (deterministic local mock, UI development only)
# PLASMO_PUBLIC_USE_MOCK_ANALYZE=1
