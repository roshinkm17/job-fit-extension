# =============================================================================
# Job Fit monorepo — local environment
# =============================================================================
# Copy to the repo root as `.env.local` (the apps read it via Vite / tsx):
#
#   cp .env.example .env.local
#
# The backend (`pnpm` scripts in `apps/backend`) loads `../../.env.local`.
# The web app (`apps/web`) loads from the monorepo root (see `vite.config.ts`).
# Never commit `.env.local` / `.env` — they are gitignored.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM (required for POST /analyze on the Fastify backend)
# ---------------------------------------------------------------------------
# openai | anthropic | groq
LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Optional proxy endpoints
# OPENAI_BASE_URL=
# ANTHROPIC_BASE_URL=
# GROQ_BASE_URL=

# ---------------------------------------------------------------------------
# Supabase (backend + web + extension build-time public keys)
# ---------------------------------------------------------------------------
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: explicit Vite env (otherwise `apps/web` falls back to SUPABASE_*)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Fastify backend (`apps/backend`)
# ---------------------------------------------------------------------------
# BACKEND_PORT=3000
# BACKEND_HOST=0.0.0.0
# NODE_ENV=development
# BACKEND_LOG_LEVEL=info

# Comma-separated origins, exact match. Must include the preferences web app
# and the Chrome extension when using the real analyzer from LinkedIn, e.g.:
#   http://localhost:5173,http://127.0.0.1:5173,chrome-extension://abcdefghijklmnop
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM call tuning (optional)
# ANALYZE_TEMPERATURE=0.2
# ANALYZE_MAX_OUTPUT_TOKENS=600

# ---------------------------------------------------------------------------
# Preferences web app (`apps/web` via Vite)
# ---------------------------------------------------------------------------
VITE_BACKEND_URL=http://localhost:3000

# After you load the unpacked extension, copy the id from chrome://extensions
# (Developer mode) so the web app can hand the session to the extension.
VITE_CHROME_EXTENSION_ID=

# ---------------------------------------------------------------------------
# Root scripts
# ---------------------------------------------------------------------------
# RLS_TEST_USER_PASSWORD=...
# pnpm verify:rls
# pnpm seed:web-user  — also uses:
# WEB_SMOKE_EMAIL=web-smoke@jobfit.local
# WEB_SMOKE_PASSWORD=WebSmoke_ChangeMe123!

# ---------------------------------------------------------------------------
# Backend smoke script: `pnpm --filter @job-fit/backend smoke`
# ---------------------------------------------------------------------------
# BACKEND_SMOKE_URL=http://127.0.0.1:3000
# BACKEND_SMOKE_EMAIL=smoke@jobfit.local
# BACKEND_SMOKE_PASSWORD=SmokeTest_ChangeMe123!

# =============================================================================
# Chrome extension (`apps/extension`) — separate file
# =============================================================================
# Plasmo reads `apps/extension/.env` (not the root file). Copy:
#
#   cp apps/extension/.env.example apps/extension/.env
#
# Or symlink public values from root. Required keys:
#   PLASMO_PUBLIC_BACKEND_URL
#   PLASMO_PUBLIC_SUPABASE_URL          (same project as above)
#   PLASMO_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   PLASMO_PUBLIC_WEB_APP_URL
# Optional: PLASMO_PUBLIC_USE_MOCK_ANALYZE=1  (skip HTTP, use deterministic mock)
# =============================================================================
