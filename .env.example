# Copy to .env (same directory) and fill in the keys you need.
# .env is gitignored — do not commit real keys.

# Which provider the LLM adapter should talk to. Default: openai.
# Supported: openai | anthropic | groq
LLM_PROVIDER=openai

# Model override. Leave unset to use the adapter's default per provider.
# Suggested starting points (cost-minimal):
#   openai    -> gpt-4o-mini (default) or gpt-4.1-nano (cheaper)
#   groq      -> llama-3.3-70b-versatile (default) or llama-3.1-8b-instant (cheapest)
#   anthropic -> claude-3-5-haiku-latest (default)
# LLM_MODEL=gpt-4o-mini

# Provider API keys. Only the key for the selected provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Optional: override provider endpoints (e.g. for local proxies).
# OPENAI_BASE_URL=
# ANTHROPIC_BASE_URL=
# GROQ_BASE_URL=

# Supabase project (Phase 3)
SUPABASE_PROJECT_ID=lokcsniznppczuhdyhnx
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: password used by scripts/supabase/verify-rls.ts for temporary test users.
# RLS_TEST_USER_PASSWORD=RlsTest_ChangeMe123!

# Backend service (Phase 4)
# BACKEND_PORT=3000
# BACKEND_HOST=0.0.0.0
# BACKEND_LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (exact match, no wildcards).
# BACKEND_CORS_ORIGINS=http://localhost:5173,chrome-extension://<your-extension-id>
# ANALYZE_TEMPERATURE=0.2
# ANALYZE_MAX_OUTPUT_TOKENS=600

# Optional overrides for the backend smoke script.
# BACKEND_SMOKE_URL=http://127.0.0.1:3000
# BACKEND_SMOKE_EMAIL=smoke@jobfit.local
# BACKEND_SMOKE_PASSWORD=SmokeTest_ChangeMe123!